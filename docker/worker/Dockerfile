FROM authentik/server:2026.2.6

ARG POSTGRESQL_ADDON_HOST
ARG POSTGRESQL_ADDON_DB
ARG POSTGRESQL_ADDON_PASSWORD
ARG POSTGRESQL_ADDON_USER
ARG POSTGRESQL_ADDON_PORT
ARG AUTHENTIK_SECRET_KEY

ENV AUTHENTIK_POSTGRESQL__HOST=$POSTGRESQL_ADDON_HOST
ENV AUTHENTIK_POSTGRESQL__NAME=$POSTGRESQL_ADDON_DB
ENV AUTHENTIK_POSTGRESQL__PASSWORD=$POSTGRESQL_ADDON_PASSWORD
ENV AUTHENTIK_POSTGRESQL__USER=$POSTGRESQL_ADDON_USER
ENV AUTHENTIK_POSTGRESQL__PORT=$POSTGRESQL_ADDON_PORT
ENV AUTHENTIK_SECRET_KEY=$AUTHENTIK_SECRET_KEY
ENV AUTHENTIK_ERROR_REPORTING__ENABLED=1
ENV AUTHENTIK_LISTEN__HTTP=0.0.0.0:8080

# Run migrations with server
ENV AUTHENTIK_SKIP_MIGRATIONS=1

CMD ["worker"]